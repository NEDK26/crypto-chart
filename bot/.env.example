# Binance API
BINANCE_API_KEY=your_api_key
BINANCE_SECRET_KEY=your_secret_key

# Trading Config
TRADING_PAIR=BTCUSDT
TRADING_INTERVAL=1m

# Risk Management
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=0.02

# Logging
LOG_LEVEL=info

# Market server (for frontend data API/WS)
MARKET_SERVER_HOST=0.0.0.0
MARKET_SERVER_PORT=4180
MARKET_SERVER_BINANCE_TIMEOUT_MS=8000
MARKET_SERVER_BINANCE_BASE_URLS=https://data-api.binance.vision,https://api.binance.com,https://api1.binance.com,https://api2.binance.com,https://api3.binance.com
